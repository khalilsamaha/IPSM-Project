generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  RECEPTION
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum FamilyStatus {
  ACTIVE
  INACTIVE
}

enum StudentStatus {
  ACTIVE
  INACTIVE
}

enum SeasonStatus {
  PLANNED
  ACTIVE
  CLOSED
  ARCHIVED
}

enum TeacherStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  ENDED
  CANCELLED
}

enum ScheduleSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  MISSED
}

model UserProfile {
  id               String     @id @default(uuid()) @db.Uuid
  authId           String     @unique @map("auth_id") @db.Uuid
  name             String
  email            String     @unique
  role             Role       @default(RECEPTION)
  status           UserStatus @default(ACTIVE)
  paymentsCreated  Payment[]  @relation("PaymentCreatedBy")
  expensesCreated  Expense[]  @relation("ExpenseCreatedBy")
  auditLogsCreated AuditLog[] @relation("AuditLogCreatedBy")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")
  archivedAt       DateTime?  @map("archived_at")

  @@map("users")
}

model AuditLog {
  id          String       @id @default(uuid()) @db.Uuid
  actorId     String?      @map("actor_id") @db.Uuid
  createdById String?      @map("created_by_id") @db.Uuid
  createdBy   UserProfile? @relation("AuditLogCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  action      String
  entity      String
  entityId    String?      @map("entity_id") @db.Uuid
  metadata    Json?
  createdAt   DateTime     @default(now()) @map("created_at")

  @@index([createdById])
  @@index([entity, entityId])
  @@map("audit_logs")
}

model Family {
  id         String       @id @default(uuid()) @db.Uuid
  name       String
  email      String?
  phone      String?
  status     FamilyStatus @default(ACTIVE)
  notes      String?
  students   Student[]
  payments   Payment[]
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  archivedAt DateTime?    @map("archived_at")

  @@index([status])
  @@map("families")
}

model Student {
  id          String        @id @default(uuid()) @db.Uuid
  familyId    String        @map("family_id") @db.Uuid
  family      Family        @relation(fields: [familyId], references: [id], onDelete: Restrict)
  firstName   String        @map("first_name")
  lastName    String        @map("last_name")
  email       String?
  phone       String?
  dateOfBirth DateTime?     @map("date_of_birth") @db.Date
  status      StudentStatus @default(ACTIVE)
  enrollments Enrollment[]
  scheduleSessions ScheduleSession[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  archivedAt  DateTime?     @map("archived_at")

  @@index([familyId])
  @@index([status])
  @@map("students")
}

model Season {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  startDate   DateTime     @map("start_date") @db.Date
  endDate     DateTime     @map("end_date") @db.Date
  status      SeasonStatus @default(PLANNED)
  enrollments Enrollment[]
  scheduleSessions ScheduleSession[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  archivedAt  DateTime?    @map("archived_at")

  @@index([status, startDate, endDate])
  @@map("seasons")
}

model Teacher {
  id              String        @id @default(uuid()) @db.Uuid
  fullName        String        @map("full_name")
  phone           String?
  email           String?       @unique
  hourlyRateCents Int           @default(0) @map("hourly_rate_cents")
  status          TeacherStatus @default(ACTIVE)
  notes           String?
  enrollments     Enrollment[]
  scheduleSessions ScheduleSession[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  archivedAt      DateTime?     @map("archived_at")

  @@index([status])
  @@map("teachers")
}

model Enrollment {
  id             String           @id @default(uuid()) @db.Uuid
  studentId      String           @map("student_id") @db.Uuid
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  seasonId       String           @map("season_id") @db.Uuid
  season         Season           @relation(fields: [seasonId], references: [id], onDelete: Restrict)
  teacherId      String?          @map("teacher_id") @db.Uuid
  teacher        Teacher?         @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  courseName     String           @map("course_name")
  feeCents       Int              @default(0) @map("fee_cents")
  discountCents  Int              @default(0) @map("discount_cents")
  finalFeeCents  Int              @default(0) @map("final_fee_cents")
  paidCents      Int              @default(0) @map("paid_cents")
  remainingCents Int              @default(0) @map("remaining_cents")
  status         EnrollmentStatus @default(ACTIVE)
  paymentItems   PaymentItem[]
  scheduleSessions ScheduleSession[]
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  archivedAt     DateTime?        @map("archived_at")

  @@unique([studentId, seasonId, courseName])
  @@index([studentId])
  @@index([seasonId])
  @@index([teacherId])
  @@index([status])
  @@map("enrollments")
}

model ScheduleSession {
  id           String                @id @default(uuid()) @db.Uuid
  studentId    String                @map("student_id") @db.Uuid
  student      Student               @relation(fields: [studentId], references: [id], onDelete: Restrict)
  teacherId    String                @map("teacher_id") @db.Uuid
  teacher      Teacher               @relation(fields: [teacherId], references: [id], onDelete: Restrict)
  enrollmentId String?               @map("enrollment_id") @db.Uuid
  enrollment   Enrollment?           @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  seasonId     String?               @map("season_id") @db.Uuid
  season       Season?               @relation(fields: [seasonId], references: [id], onDelete: SetNull)
  title        String?
  sessionDate  DateTime              @map("session_date") @db.Date
  startTime    String                @map("start_time")
  endTime      String                @map("end_time")
  status       ScheduleSessionStatus @default(SCHEDULED)
  notes        String?
  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")
  archivedAt   DateTime?             @map("archived_at")

  @@index([studentId, sessionDate])
  @@index([teacherId, sessionDate])
  @@index([enrollmentId])
  @@index([seasonId])
  @@index([status])
  @@map("schedule_sessions")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  familyId         String        @map("family_id") @db.Uuid
  family           Family        @relation(fields: [familyId], references: [id], onDelete: Restrict)
  paymentDate      DateTime      @default(now()) @map("payment_date") @db.Date
  paymentMethod    String        @map("payment_method")
  totalAmountCents Int           @map("total_amount_cents")
  notes            String?
  createdById      String?       @map("created_by_id") @db.Uuid
  createdBy        UserProfile?  @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  receiptNumber    String?       @unique @map("receipt_number")
  voidedAt         DateTime?     @map("voided_at")
  items            PaymentItem[]
  receipt          Receipt?
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  @@index([familyId])
  @@index([createdById])
  @@index([paymentDate])
  @@map("payments")
}

model PaymentItem {
  id           String     @id @default(uuid()) @db.Uuid
  paymentId    String     @map("payment_id") @db.Uuid
  payment      Payment    @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  enrollmentId String     @map("enrollment_id") @db.Uuid
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Restrict)
  amountCents  Int        @map("amount_cents")
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([paymentId, enrollmentId])
  @@index([paymentId])
  @@index([enrollmentId])
  @@map("payment_items")
}

model Receipt {
  id                 String    @id @default(uuid()) @db.Uuid
  paymentId          String    @unique @map("payment_id") @db.Uuid
  payment            Payment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  receiptNumber      String    @unique @map("receipt_number")
  pdfPath            String?   @map("pdf_path")
  generatedAt        DateTime  @default(now()) @map("generated_at")
  sentByEmailAt      DateTime? @map("sent_by_email_at")
  sharedByWhatsappAt DateTime? @map("shared_by_whatsapp_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  deletedAt          DateTime? @map("deleted_at")

  @@index([generatedAt])
  @@map("receipts")
}

model Expense {
  id            String       @id @default(uuid()) @db.Uuid
  createdById   String?      @map("created_by_id") @db.Uuid
  createdBy     UserProfile? @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  category      String
  description   String
  amountCents   Int          @map("amount_cents")
  incurredAt    DateTime     @default(now()) @map("incurred_at") @db.Date
  expenseDate   DateTime     @default(now()) @map("expense_date") @db.Date
  paymentMethod String       @default("cash") @map("payment_method")
  createdAt     DateTime     @default(now()) @map("created_at")
  archivedAt    DateTime?    @map("archived_at")

  @@index([createdById])
  @@index([expenseDate])
  @@map("expenses")
}
